# Test Environment Configuration
# Copy this file to .env.test for test database isolation
# Only overrides specific test variables - other values inherited from .env

# PostgreSQL - Test Database
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/langfuse_test"
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/langfuse_test"

# Doris analytics backend - Test Database
DORIS_FE_HTTP_URL="http://localhost:8030"
DORIS_FE_QUERY_PORT="9030"
DORIS_DB="langfuse_test"
DORIS_USER="root"
DORIS_PASSWORD=""

# pg-boss scheduled job backend
LITEFUSE_PG_BOSS_ENABLED="true"
LITEFUSE_PG_BOSS_SCHEMA="pgboss"
LITEFUSE_PG_BOSS_MIGRATE="true"
LITEFUSE_PG_BOSS_SCHEDULE_TZ="UTC"
LITEFUSE_PG_BOSS_CONNECTION_TIMEOUT_MS="30000"
LITEFUSE_PG_BOSS_POOL_MAX="5"

# Batch export downloads
BATCH_EXPORT_DOWNLOAD_TOKEN_SECRET="test-batch-export-token-secret"
BATCH_EXPORT_PAGE_SIZE="500"
BATCH_EXPORT_ROW_LIMIT="1500000"
BATCH_EXPORT_DOWNLOAD_LINK_EXPIRATION_HOURS="24"
LITEFUSE_DORIS_PARTITION_RETENTION_DAYS="30"